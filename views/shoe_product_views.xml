<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree View -->
    <record id="view_shoe_product_tree" model="ir.ui.view">
        <field name="name">shoe.product.tree</field>
        <field name="model">shoe.product</field>
        <field name="arch" type="xml">
            <tree string="Shoe Products">
                <field name="default_code"/>
                <field name="name"/>
                <field name="brand"/>
                <field name="gender"/>
                <field name="season"/>
                <field name="list_price"/>
                <field name="variant_count"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_shoe_product_form" model="ir.ui.view">
        <field name="name">shoe.product.form</field>
        <field name="model">shoe.product</field>
        <field name="arch" type="xml">
            <form string="Shoe Product">
                <header>
                    <button name="action_generate_variants"
                            string="Generate Variants"
                            type="object"
                            class="oe_highlight"
                            invisible="not size_ids or not color_ids"/>
                </header>
                <sheet>
                    <field name="image_1920" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <label for="name" string="Product Name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Nike Air Max 270"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="default_code"/>
                            <field name="brand"/>
                            <field name="categ_id"/>
                            <field name="gender"/>
                            <field name="season"/>
                        </group>
                        <group>
                            <field name="list_price"/>
                            <field name="standard_price"/>
                            <field name="variant_count"/>
                            <field name="total_qty_available"/>
                            <field name="total_virtual_available"/>
                            <field name="active"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Sizes &amp; Colors">
                            <group>
                                <field name="size_ids" widget="many2many_tags"/>
                                <field name="color_ids" widget="many2many_tags"
                                       options="{'color_field': 'code'}"/>
                            </group>
                        </page>

                        <page string="Variants">
                            <field name="variant_ids" readonly="1">
                                <tree string="Product Variants"
                                      decoration-muted="not active">
                                    <field name="display_name"/>
                                    <field name="size_id"/>
                                    <field name="color_id"/>
                                    <field name="qty_available"/>
                                    <field name="virtual_available"/>
                                    <field name="list_price"/>
                                    <field name="barcode"/>
                                    <field name="active" invisible="1"/>
                                </tree>
                            </field>
                        </page>

                        <page string="Description">
                            <field name="description" placeholder="Product description..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_shoe_product_kanban" model="ir.ui.view">
        <field name="name">shoe.product.kanban</field>
        <field name="model">shoe.product</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="id"/>
                <field name="name"/>
                <field name="brand"/>
                <field name="list_price"/>
                <field name="image_1920"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_image">
                                <img t-att-src="kanban_image('shoe.product', 'image_1920', record.id.raw_value)"
                                     alt="Product" class="o_image_64_cover"/>
                            </div>
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <div>
                                    <field name="brand"/>
                                </div>
                                <div>
                                    <field name="list_price" widget="monetary"/>
                                </div>
                                <div>
                                    Variants: <field name="variant_count"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_shoe_product_search" model="ir.ui.view">
        <field name="name">shoe.product.search</field>
        <field name="model">shoe.product</field>
        <field name="arch" type="xml">
            <search string="Search Shoe Products">
                <field name="name"/>
                <field name="default_code"/>
                <field name="brand"/>
                <filter string="Men" name="filter_men"
                        domain="[('gender', '=', 'men')]"/>
                <filter string="Women" name="filter_women"
                        domain="[('gender', '=', 'women')]"/>
                <filter string="Kids" name="filter_kids"
                        domain="[('gender', '=', 'kids')]"/>
                <separator/>
                <filter string="Summer" name="filter_summer"
                        domain="[('season', '=', 'summer')]"/>
                <filter string="Winter" name="filter_winter"
                        domain="[('season', '=', 'winter')]"/>
                <group expand="0" string="Group By">
                    <filter string="Brand" name="group_brand"
                            context="{'group_by': 'brand'}"/>
                    <filter string="Gender" name="group_gender"
                            context="{'group_by': 'gender'}"/>
                    <filter string="Season" name="group_season"
                            context="{'group_by': 'season'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_shoe_product" model="ir.actions.act_window">
        <field name="name">Shoe Products</field>
        <field name="res_model">shoe.product</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="search_view_id" ref="view_shoe_product_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first shoe product
            </p>
            <p>
                Define shoe products with their sizes and colors, then generate variants automatically.
            </p>
        </field>
    </record>

</odoo>