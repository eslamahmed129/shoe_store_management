<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Add Size and Color to Sale Order Line Tree -->
    <record id="view_order_form_inherit_shoe" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.shoe</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']/tree/field[@name='product_id']" position="after">
                <field name="shoe_size" optional="show"/>
                <field name="shoe_color" optional="show"/>
            </xpath>
        </field>
    </record>

    <!-- Add Size and Color to Purchase Order Line Tree -->
    <record id="view_purchase_order_form_inherit_shoe" model="ir.ui.view">
    <field name="name">purchase.order.form.inherit.shoe</field>
    <field name="model">purchase.order</field>
    <field name="inherit_id" ref="purchase.purchase_order_form"/>
    <field name="arch" type="xml">
        <xpath expr="//field[@name='order_line']//tree//field[@name='product_id']"
               position="after">
            <field name="shoe_size" optional="show"/>
            <field name="shoe_color" optional="show"/>
        </xpath>
    </field>
    </record>

</odoo>